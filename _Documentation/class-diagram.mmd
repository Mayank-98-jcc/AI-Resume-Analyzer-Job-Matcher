classDiagram
  direction TB

  class User {
    +name
    +email
    +role
    +plan
  }

  class Resume {
    +fileName
    +skills
    +atsScore
    +suggestions
  }

  class Support {
    +category
    +status
    +lastMessage
  }

  class AuthController {
    +registerUser()
    +loginUser()
    +verifyOtp()
  }

  class ResumeController {
    +uploadResume()
    +getHistory()
    +generateSummary()
  }

  class BillingController {
    +createOrder()
    +verifyPayment()
    +getUserBilling()
  }

  class SupportController {
    +createSupportMessage()
    +getUserFeedbackHistory()
  }

  class GeminiService {
    +generateSummary()
    +compareResumeWithJobDescription()
  }

  User "1" --> "0..*" Resume : uploads
  User "1" --> "0..*" Support : creates

  AuthController ..> User : manages
  ResumeController ..> Resume : analyzes
  ResumeController ..> GeminiService : uses
  BillingController ..> User : updates plan
  SupportController ..> Support : manages
