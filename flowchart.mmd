  }
}}%%
flowchart TD
  %% ResumeIQ overview for documentation and A4 layout

  Start([User visits ResumeIQ]) --> Auth{Authenticated?}
  Auth -->|No| Login[Login or sign up]
  Auth -->|Yes| Dashboard[Open dashboard]
  Login --> Dashboard

  subgraph UserFlow["User Workflow"]
    Dashboard --> Upload[Upload resume]
    Upload --> Validate{File valid?}
    Validate -->|No| UploadError[Show validation error]
    Validate -->|Yes| Analyze[Extract and analyze resume]
    Analyze --> Results[Show ATS score,<br/>skills, and suggestions]
    Results --> History[(Save report in history)]
    History --> UseFeatures[Review results and<br/>improve resume]
    UploadError --> Upload
  end

  subgraph PaymentFlow["Premium    and Payment"]
    PaymentSpacer[" "]
    UseFeatures --> PaymentSpacer
    PaymentSpacer --> PremiumNeed{Need premium feature?}
    PremiumNeed -->|No| Continue[Continue with free features]
    PremiumNeed -->|Yes| Billing[Open billing page]
    Billing --> Payment[Complete payment]
    Payment --> PaymentVerify{Payment successful?}
    PaymentVerify -->|No| PaymentError[Show retry message]
    PaymentVerify -->|Yes| PremiumAccess[Unlock premium tools]
    PremiumAccess --> UseFeatures
    PaymentError --> Billing
  end

  subgraph SupportFlow["Support"]
    UseFeatures --> Support[Send feedback or support request]
    Support --> Reply[Store message and<br/>send reply]
  end

  subgraph AdminFlow["Admin Overview"]
    History -.-> Admin[Admin panel]
    PaymentVerify -.-> Admin
    Reply -.-> Admin
    Admin --> Monitor[Monitor users, resumes,<br/>payments, and feedback]
  end

  Continue --> End([End])
  Reply --> End
  Monitor --> End

  classDef normal fill:#f8fafc,stroke:#64748b,color:#0f172a;
  classDef gate fill:#e2e8f0,stroke:#475569,color:#0f172a;
  classDef success fill:#dcfce7,stroke:#15803d,color:#14532d;
  classDef warn fill:#fee2e2,stroke:#b91c1c,color:#7f1d1d;
  classDef store fill:#ede9fe,stroke:#7c3aed,color:#4c1d95;
  classDef hidden fill:transparent,stroke:transparent,color:transparent;

  class Login,Dashboard,Upload,Analyze,Results,UseFeatures,Billing,Payment,Support,Reply,Admin,Monitor,Continue normal;
  class Auth,Validate,PremiumNeed,PaymentVerify gate;
  class PremiumAccess,End success;
  class UploadError,PaymentError warn;
  class History store;
  class PaymentSpacer hidden;
