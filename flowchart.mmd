  "theme": "base",
  "themeVariables": {
    "fontSize": "24px",
    "background": "#ffffff",
    "primaryColor": "#f8fafc",
    "primaryTextColor": "#0f172a",
    "primaryBorderColor": "#475569",
    "lineColor": "#475569",
    "secondaryColor": "#eef2ff",
    "tertiaryColor": "#f8fafc"
  },
  "themeCSS": ".mermaid, .mermaid svg, svg { background: #ffffff !important; } .label, .nodeLabel, .edgeLabel, .label text, tspan { fill: #0f172a !important; font-size: 20px !important; } .cluster rect { rx: 12 !important; ry: 12 !important; stroke-width: 1.5px !important; } .node rect, .node polygon, .node path, .node circle { stroke-width: 1.8px !important; }",
  "flowchart": {
    "nodeSpacing": 40,
    "rankSpacing": 52,
